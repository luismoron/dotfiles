bindsym $mod+m bar mode toggle


# Start i3bar to display a workspace bar (plus the system information i3status
# finds out, if available)
bar {
    font xft:Roboto 11
    status_command i3status -c $HOME/Plantillas/dotfiles/i3status/i3status.conf | $HOME/Plantillas/dotfiles/i3status/i3spotifystatus/pystatus.py
    tray_output eDP
    colors {
        background #081e2d
        statusline #fefefe
        separator  #454947

#                           border  backgr. text
        focused_workspace  #d5d2e2 #235260 #ffffff
        active_workspace   #595B5B #353836 #FDF6E3
        inactive_workspace #595B5B #081e2d #EEE8D5
        binding_mode       #d5d2e2 #235260 #ffffff
        urgent_workspace   #005577 #FDF6E3 #E5201D
    }
}



